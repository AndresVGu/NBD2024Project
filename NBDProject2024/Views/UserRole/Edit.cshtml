@model NBDProject2024.ViewModels.UserVM

<partial name="_ViewHeading" />

<form asp-action="Edit">
    <hr />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    @if (ViewBag.LockRootRole == true)
    {
        <div class="alert alert-warning">@ViewBag.RootLockReason</div>
    }
    <input type="hidden" asp-for="ID" />
    <div class="row">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="form-group">
                <label asp-for="UserName" class="control-label"></label>
                <input asp-for="UserName" class="form-control" readonly="readonly"/>
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UserRoles" class="control-label"></label>
                <div class="table-responsive">
                <table class="table table-borderless table-sm align-middle mb-0">
                    <tr>
                        @{
                            int cnt = 0;
                            List<NBDProject2024.ViewModels.RoleVM> roles = ViewBag.Roles;
                            foreach (var role in roles)
                            {
                                if (cnt++ % 3 == 0)
                                {
                                @:</tr><tr>
                                }
                                var lockRoot = (bool?)(ViewBag.LockRootRole) == true;
                                var disableRole = lockRoot && role.RoleName == "Root";
                                @:<td>
                                    <input type="checkbox"
                                           name="selectedRoles"
                                           value="@role.RoleName"
                                           @(Html.Raw(role.Assigned ? "checked=\"checked\"" : ""))
                                           @(disableRole ? "disabled=\"disabled\"" : "") />
                                    @if (disableRole && role.Assigned)
                                    {
                                        <input type="hidden" name="selectedRoles" value="Root" />
                                    }
                                    @role.RoleName @:&nbsp;&nbsp;
                                @:</td>
                            }
                        @:</tr>
                        }
                    </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="form-group">
                    <input type="submit" id="btnSubmit" value="Save" class="btn btn-primary" />
                </div>
            </div>
        </div>
    </form>

    <div>
        <partial name="_BackToList" />
    </div>


