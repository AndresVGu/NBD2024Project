@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="veridia-landing" id="top">
    <section class="py-5 landing-section">
        <div class="container">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-lg-6">
                    <span class="landing-chip">Smart Management</span>
                    <h1 class="landing-hero-title mt-3">NBD Landscaping Management Platform</h1>
                    <p class="landing-hero-copy mt-3">An enterprise-style ASP.NET Core platform built for landscaping operations, from client onboarding to project planning and bid composition.</p>
                    <div class="d-flex flex-wrap gap-3 mt-4">
                        <a asp-area="" asp-controller="Login" asp-action="Guest" class="btn btn-success rounded-pill px-4">Guest User</a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-success rounded-pill px-4">LogIn</a>
                    </div>
                    <p class="small text-secondary mt-3 mb-0">
                        To switch between Light and Dark mode, use the sun/moon button in the top-right corner.
                    </p>
                </div>
                <div class="col-lg-6">
                    <div class="hero-image-wrap position-relative">
                        <img src="~/assets/1.png" class="img-fluid rounded-4 shadow w-100" alt="NBD demo" />
                        <div class="floating-stat stat-top shadow-sm rounded-4">
                            <i class="bi bi-calendar-check"></i>
                            <div>
                                <div class="fw-bold">$125,000</div>
                                <small>Active budget</small>
                            </div>
                        </div>
                        <div class="floating-stat stat-bottom shadow-sm rounded-4">
                            <i class="bi bi-graph-up-arrow"></i>
                            <div>
                                <small>Completed projects: 48</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 landing-section-alt">
        <div class="container">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Core Product Scope</h2>
                <p class="text-secondary mb-0">Built for real business workflows, not just CRUD screens.</p>
            </div>

            <div class="row g-3 g-md-4">
                <div class="col-6 col-md-3">
                    <div class="card h-100 rounded-4 shadow-sm feature-card">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-pencil-square fs-2 feature-icon"></i>
                            <h6 class="mt-3 mb-2 fw-semibold">Client Management</h6>
                            <p class="small text-secondary mb-0">Capture customer data, contact details, and relationship history in one source of truth.</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 rounded-4 shadow-sm feature-card">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-boxes fs-2 feature-icon"></i>
                            <h6 class="mt-3 mb-2 fw-semibold">Project Management</h6>
                            <p class="small text-secondary mb-0">Define scopes, schedule windows, and track project lifecycle from planning to delivery.</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 rounded-4 shadow-sm feature-card">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-calendar3 fs-2 feature-icon"></i>
                            <h6 class="mt-3 mb-2 fw-semibold">Bid Composition</h6>
                            <p class="small text-secondary mb-0">Build project bids with itemized material and labour line items for transparent estimating.</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="card h-100 rounded-4 shadow-sm feature-card">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-file-earmark-bar-graph fs-2 feature-icon"></i>
                            <h6 class="mt-3 mb-2 fw-semibold">Identity and Security</h6>
                            <p class="small text-secondary mb-0">Role assignment, access governance, and account lifecycle for operational control.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 landing-section">
        <div class="container">
            <h2 class="fw-bold text-center mb-4">Operational Workflow in Practice</h2>

            <div class="card rounded-4 shadow-sm mb-4 package-card">
                <div class="row g-0 align-items-center">
                    <div class="col-md-5">
                        <img src="~/assets/2.png" class="img-fluid rounded-start-4 h-100 object-fit-cover w-100 package-img" alt="Base package" />
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-2">Sales to Planning Pipeline</h4>
                            <span class="badge text-bg-success me-1">Client Onboarding</span>
                            <span class="badge text-bg-success">Project Definition</span>
                            <p class="fst-italic mt-3 mb-1">How teams use it:</p>
                            <p class="mb-2">Register a client profile, then create one or more linked projects.</p>
                            <p class="small text-secondary">This workflow aligns sales and operations with a consistent process order before estimating begins.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card rounded-4 shadow-sm mb-4 package-card">
                <div class="row g-0 align-items-center flex-md-row-reverse">
                    <div class="col-md-5">
                        <img src="~/assets/3.png" class="img-fluid rounded-end-4 h-100 object-fit-cover w-100 package-img" alt="Pro package" />
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-2">Estimating and Governance Pipeline</h4>
                            <span class="badge text-bg-success me-1">Bid Composition</span>
                            <span class="badge text-bg-success">Role Governance</span>
                            <p class="fst-italic mt-3 mb-1">How teams use it:</p>
                            <p class="mb-2">Build bids per project and attach material/labour entries with role-based control.</p>
                            <p class="small text-secondary">Supports Admin, Supervisor, Sales, and Designer collaboration while preserving accountability.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 landing-section-alt">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-lg-5">
                    <img src="~/assets/4.png" class="img-fluid rounded-4 shadow" alt="NBD services" />
                </div>
                <div class="col-lg-7">
                    <div class="accordion accordion-flush veridia-accordion" id="serviciosAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h1">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#c1" aria-expanded="true" aria-controls="c1">Step 1: Register Client</button>
                            </h2>
                            <div id="c1" class="accordion-collapse collapse show" aria-labelledby="h1" data-bs-parent="#serviciosAccordion">
                                <div class="accordion-body">Create a reliable customer profile with company, location, and contact context before operations start.</div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h2">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c2" aria-expanded="false" aria-controls="c2">Step 2: Define Project</button>
                            </h2>
                            <div id="c2" class="accordion-collapse collapse" aria-labelledby="h2" data-bs-parent="#serviciosAccordion">
                                <div class="accordion-body">Create one or more projects per client with scope, dates, and site details for planning handoff.</div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h3">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c3" aria-expanded="false" aria-controls="c3">Step 3: Build Bid</button>
                            </h2>
                            <div id="c3" class="accordion-collapse collapse" aria-labelledby="h3" data-bs-parent="#serviciosAccordion">
                                <div class="accordion-body">Compose project bids with structured commercial data and transparent estimating fields.</div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h4">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c4" aria-expanded="false" aria-controls="c4">Step 4: Add Line Items</button>
                            </h2>
                            <div id="c4" class="accordion-collapse collapse" aria-labelledby="h4" data-bs-parent="#serviciosAccordion">
                                <div class="accordion-body">Attach BidMaterials and BidLabours to each bid for granular quantities, prices, and hours.</div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="h5">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c5" aria-expanded="false" aria-controls="c5">Step 5: Govern Access</button>
                            </h2>
                            <div id="c5" class="accordion-collapse collapse" aria-labelledby="h5" data-bs-parent="#serviciosAccordion">
                                <div class="accordion-body">Control who can create, edit, approve, and administer records through role-based authorization.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-5 landing-section">
        <div class="container">
            <div class="enterprise-ready-box rounded-4 p-4 p-md-5">
                <div class="row align-items-center g-4">
                    <div class="col-lg-7">
                        <h2 class="fw-bold text-white mb-3">Enterprise-ready foundation for landscaping operations</h2>
                        <p class="text-white-50 mb-4">Built with ASP.NET Core MVC, EF Core 8, Identity roles, and practical workflow governance for real commercial landscaping teams.</p>
                        <a asp-area="" asp-controller="Login" asp-action="Guest" class="btn btn-light rounded-pill px-4 enterprise-cta-btn">Launch Guest Demo</a>
                    </div>
                    <div class="col-lg-5 text-center">
                        <img src="~/assets/5.png" class="img-fluid rounded-4 enterprise-ready-image" alt="Enterprise-ready NBD" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="veridia-footer py-4 border-top">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <small>2026 NBD. All rights reserved.</small>
            <small>NBD: Smart Landscape Management</small>
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        (function () {
            var storageKey = "veridia-landing-theme";
            var saved = localStorage.getItem(storageKey);
            document.body.setAttribute("data-bs-theme", saved === "dark" ? "dark" : "light");
        })();
    </script>
}
