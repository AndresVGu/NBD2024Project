@model IEnumerable<NBDProject2024.Models.Employee>

<partial name="_ViewHeading" />

@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-success">@TempData["AlertMessage"]</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>Employee</th>
                <th>Status</th>
                <th>Skills</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var skills = item.EmployeeSkills
                    .OrderBy(s => s.Skill)
                    .Select(s => $"{s.Skill} (L{s.Level})");
                <tr>
                    <td>@item.FirstName @item.LastName</td>
                    <td>@(item.Active ? "Active" : "Inactive")</td>
                    <td>@(skills.Any() ? string.Join(", ", skills) : "-")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">Edit Skills</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
