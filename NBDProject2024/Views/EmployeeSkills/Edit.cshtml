@model NBDProject2024.ViewModels.EmployeeSkillEditVM

<partial name="_ViewHeading" />

<h5 class="mb-3">@Model.EmployeeName</h5>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="EmployeeID" />

    <div class="table-responsive mb-3">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Skill</th>
                    <th>Enabled</th>
                    <th>Level (1-5)</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Skills.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" asp-for="Skills[i].Skill" />
                            @Model.Skills[i].Skill
                        </td>
                        <td>
                            <input asp-for="Skills[i].Selected" class="form-check-input" />
                        </td>
                        <td>
                            <input asp-for="Skills[i].Level" class="form-control" type="number" min="1" max="5" />
                            <span asp-validation-for="Skills[i].Level" class="text-danger"></span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="submit" class="btn btn-primary">Save Skills</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
