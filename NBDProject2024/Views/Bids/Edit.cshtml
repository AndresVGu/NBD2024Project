@model NBDProject2024.Models.Bid

<partial name="_ViewHeading" />
<hr />
<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="ID" />
    <input type="hidden" asp-for="RowVersion" />
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="BidDate" class="control-label"></label>
                <input asp-for="BidDate" class="form-control" />
                <span asp-validation-for="BidDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProjectID" class="control-label"></label>
                <select asp-for="ProjectID" class="form-control" asp-items="ViewBag.ProjectID" id="dropdownProjects"></select>
                <span asp-validation-for="ProjectID" class="text-danger"></span>
            </div>
        </div>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-6">
            <h4>Materials</h4>
            <div id="materialRows">
                @if (Model.BidMaterials != null && Model.BidMaterials.Any())
                {
                    foreach (var item in Model.BidMaterials.OrderBy(m => m.Materials.Name))
                    {
                        <div class="row g-2 material-row mb-2">
                            <div class="col-6">
                                <select name="materialIds" class="form-control">
                                    <option value="0">Select Material</option>
                                    @foreach (var opt in (IEnumerable<SelectListItem>)ViewBag.MaterialID)
                                    {
                                        if (opt.Value == item.MaterialID.ToString())
                                        {
                                            <option value="@opt.Value" selected="selected">@opt.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@opt.Value">@opt.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-4">
                                <input type="number" min="1" step="1" name="materialQuantities" class="form-control" value="@item.MaterialQuantity" />
                            </div>
                            <div class="col-2">
                                <button type="button" class="btn btn-outline-danger remove-material">X</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="row g-2 material-row mb-2">
                        <div class="col-6">
                            <select name="materialIds" class="form-control" asp-items="ViewBag.MaterialID">
                                <option value="0">Select Material</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <input type="number" min="1" step="1" name="materialQuantities" class="form-control" value="1" />
                        </div>
                        <div class="col-2">
                            <button type="button" class="btn btn-outline-danger remove-material">X</button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" id="addMaterialRow" class="btn btn-sm btn-outline-success">Add Material</button>
        </div>

        <div class="col-md-6">
            <h4>Labours</h4>
            <div id="labourRows">
                @if (Model.BidLabours != null && Model.BidLabours.Any())
                {
                    foreach (var item in Model.BidLabours.OrderBy(l => l.Labours.Name))
                    {
                        <div class="row g-2 labour-row mb-2">
                            <div class="col-6">
                                <select name="labourIds" class="form-control">
                                    <option value="0">Select Labour</option>
                                    @foreach (var opt in (IEnumerable<SelectListItem>)ViewBag.LabourID)
                                    {
                                        if (opt.Value == item.LabourID.ToString())
                                        {
                                            <option value="@opt.Value" selected="selected">@opt.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@opt.Value">@opt.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-4">
                                <input type="number" min="0" step="0.25" name="labourHours" class="form-control" value="@item.HoursQuantity" />
                            </div>
                            <div class="col-2">
                                <button type="button" class="btn btn-outline-danger remove-labour">X</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="row g-2 labour-row mb-2">
                        <div class="col-6">
                            <select name="labourIds" class="form-control" asp-items="ViewBag.LabourID">
                                <option value="0">Select Labour</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <input type="number" min="0" step="0.25" name="labourHours" class="form-control" value="1" />
                        </div>
                        <div class="col-2">
                            <button type="button" class="btn btn-outline-danger remove-labour">X</button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" id="addLabourRow" class="btn btn-sm btn-outline-success">Add Labour</button>
        </div>
    </div>

    <hr />

    <div class="form-group">
        <input type="submit" value="Update" class="btn btn-primary" />
    </div>
</form>


<div>
    <partial name="_BackToList" />
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $('#dropdownProjects').select2({ placeholder: "Select", width: "100%" });

        $('#addMaterialRow').on('click', function () {
            var row = $('.material-row').first().clone();
            row.find('select').val('0');
            row.find('input').val('1');
            $('#materialRows').append(row);
        });

        $('#addLabourRow').on('click', function () {
            var row = $('.labour-row').first().clone();
            row.find('select').val('0');
            row.find('input').val('1');
            $('#labourRows').append(row);
        });

        $(document).on('click', '.remove-material', function () {
            if ($('.material-row').length > 1) {
                $(this).closest('.material-row').remove();
            }
        });

        $(document).on('click', '.remove-labour', function () {
            if ($('.labour-row').length > 1) {
                $(this).closest('.labour-row').remove();
            }
        });
    </script>
}
