@model NBDProject2024.Models.StockLocation

@{
    ViewData["Title"] = "Edit Location";
}

<partial name="_ViewHeading" />

<form asp-action="EditLocation" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="ID" />

    <div class="mb-2">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="LocationType" class="control-label"></label>
        <select asp-for="LocationType" class="form-control" asp-items="Html.GetEnumSelectList<NBDProject2024.Models.StockLocationType>()"></select>
    </div>

    <div class="form-check mb-2">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="control-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Locations" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
