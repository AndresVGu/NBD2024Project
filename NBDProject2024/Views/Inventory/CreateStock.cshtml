@model NBDProject2024.Models.MaterialStock

@{
    ViewData["Title"] = "Create Stock";
}

<partial name="_ViewHeading" />

<form asp-action="CreateStock" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-2">
        <label asp-for="MaterialID" class="control-label"></label>
        <select asp-for="MaterialID" class="form-control" asp-items="ViewBag.MaterialID"></select>
        <span asp-validation-for="MaterialID" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="StockLocationID" class="control-label"></label>
        <select asp-for="StockLocationID" class="form-control" asp-items="ViewBag.StockLocationID"></select>
        <span asp-validation-for="StockLocationID" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="QuantityOnHand" class="control-label"></label>
        <input asp-for="QuantityOnHand" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="MinQuantity" class="control-label"></label>
        <input asp-for="MinQuantity" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastUnitCost" class="control-label"></label>
        <input asp-for="LastUnitCost" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
