@model IEnumerable<NBDProject2024.Models.StockLocation>

@{
    ViewData["Title"] = "Stock Locations";
}

<partial name="_ViewHeading" />

@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-success">@TempData["AlertMessage"]</div>
}

<div class="d-flex gap-2 mb-3">
    <a asp-action="CreateLocation" class="btn btn-outline-primary">Add Location</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Inventory</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Active</th>
                <th>Notes</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.LocationType</td>
                    <td>@(item.IsActive ? "Yes" : "No")</td>
                    <td>@item.Notes</td>
                    <td class="text-center">
                        <a asp-action="EditLocation" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
