@model NBDProject2024.Models.WorkOrder

<partial name="_ViewHeading" />

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>

        <dt class="col-sm-3">Project</dt>
        <dd class="col-sm-9">@Model.Project?.ProjectName</dd>

        <dt class="col-sm-3">Client</dt>
        <dd class="col-sm-9">@Model.Project?.Client?.CompanyName</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ScheduledDate)</dt>
        <dd class="col-sm-9">@Model.ScheduledDate.ToString("yyyy-MMM-dd")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AssignedCrew)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.AssignedCrew)</dd>

        <dt class="col-sm-3">Estimated Hours</dt>
        <dd class="col-sm-9">@Model.EstimatedHoursTotal.ToString("0.##")</dd>

        <dt class="col-sm-3">Actual Hours</dt>
        <dd class="col-sm-9">@Model.ActualHoursTotal.ToString("0.##")</dd>

        <dt class="col-sm-3">Variance</dt>
        <dd class="col-sm-9">@Model.HoursVariance.ToString("0.##")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CompletedOn)</dt>
        <dd class="col-sm-9">@(Model.CompletedOn.HasValue ? Model.CompletedOn.Value.ToString("yyyy-MMM-dd") : "-")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>
    </dl>
</div>

@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-info">@TempData["AlertMessage"]</div>
}

<div class="card card-body mb-3">
    <h5 class="mb-3">Crew Assignment by Skill</h5>
    <form asp-action="AddCrewMember" method="post" class="row g-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.ID" />
        <div class="col-12 col-md-4">
            <label class="control-label">Employee</label>
            <select name="employeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
        </div>
        <div class="col-12 col-md-2">
            <label class="control-label">Skill</label>
            <select name="assignedSkill" class="form-control" asp-items="ViewBag.Skill"></select>
        </div>
        <div class="col-12 col-md-2">
            <label class="control-label">Est. Hours</label>
            <input name="estimatedHours" class="form-control" type="number" min="0" max="24" step="0.25" value="0" />
        </div>
        <div class="col-12 col-md-2">
            <label class="control-label">Actual Hours</label>
            <input name="actualHours" class="form-control" type="number" min="0" max="24" step="0.25" value="0" />
        </div>
        <div class="col-12 col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">Save</button>
        </div>
    </form>
</div>

<div class="table-responsive mb-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Employee</th>
                <th>Skill</th>
                <th>Estimated</th>
                <th>Actual</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.CrewAssignments.Any())
            {
                @foreach (var item in Model.CrewAssignments.OrderBy(a => a.Employee?.FirstName).ThenBy(a => a.Employee?.LastName))
                {
                    <tr>
                        <td>@item.Employee?.FirstName @item.Employee?.LastName</td>
                        <td>@item.AssignedSkill</td>
                        <td>@item.EstimatedHours.ToString("0.##")</td>
                        <td>@item.ActualHours.ToString("0.##")</td>
                        <td class="text-center">
                            <form asp-action="RemoveCrewMember" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.ID" />
                                <input type="hidden" name="employeeID" value="@item.EmployeeID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center text-muted">No crew assignments yet.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="card card-body mb-3">
    <h5 class="mb-3">Material Consumption (Inventory Output)</h5>
    @if (User.IsInRole("Admin") || User.IsInRole("Supervisor") || User.IsInRole("Root"))
    {
        <form asp-action="RecordConsumption" method="post" class="row g-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ID" />

            <div class="col-12 col-md-3">
                <label class="control-label">Material</label>
                <select name="materialID" class="form-control" asp-items="ViewBag.MaterialID"></select>
            </div>
            <div class="col-12 col-md-3">
                <label class="control-label">From Location</label>
                <select name="stockLocationID" class="form-control" asp-items="ViewBag.StockLocationID"></select>
            </div>
            <div class="col-12 col-md-2">
                <label class="control-label">Date</label>
                <input name="consumedOn" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-12 col-md-2">
                <label class="control-label">Qty Used</label>
                <input name="quantityUsed" type="number" min="0.01" step="0.01" class="form-control" />
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-warning w-100">Consume</button>
            </div>
            <div class="col-12">
                <input name="notes" class="form-control" placeholder="Notes (optional)" />
            </div>
        </form>
    }
    else
    {
        <p class="text-muted mb-0">Only Admin/Supervisor/Root can register inventory consumption.</p>
    }
</div>

<div class="table-responsive mb-3">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Material</th>
                <th>Location</th>
                <th>Qty Used</th>
                <th>Unit Cost</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.MaterialConsumptions.Any())
            {
                @foreach (var c in Model.MaterialConsumptions.OrderByDescending(x => x.ConsumedOn).ThenByDescending(x => x.ID))
                {
                    <tr>
                        <td>@c.ConsumedOn.ToString("yyyy-MMM-dd")</td>
                        <td>@c.Material?.Name</td>
                        <td>@c.StockLocation?.Name</td>
                        <td>@c.QuantityUsed.ToString("0.##")</td>
                        <td>@c.UnitCostAtUse.ToString("C2")</td>
                        <td>@((c.QuantityUsed * c.UnitCostAtUse).ToString("C2"))</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted">No material consumption recorded yet.</td></tr>
            }
        </tbody>
    </table>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model?.ID" class="btn btn-outline-danger">Delete</a>
    <a asp-action="RoutePlan" asp-route-date="@Model.ScheduledDate.ToString("yyyy-MM-dd")" class="btn btn-outline-info">View Daily Route</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
