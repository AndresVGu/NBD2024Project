@model NBDProject2024.Utilities.PaginatedList<NBDProject2024.Models.WorkOrder>

<partial name="_ViewHeading" />

<form asp-action="Index" method="get">
    <div class="card card-body bg-light mb-3">
        <div class="row g-2">
            <div class="col-12 col-md-4">
                <label class="control-label">Project</label>
                @Html.DropDownList("projectID", null, "All Projects", new { @class = "form-control" })
            </div>
            <div class="col-12 col-md-3">
                <label class="control-label">Status</label>
                @Html.DropDownList("status", null, "All Status", new { @class = "form-control" })
            </div>
            <div class="col-12 col-md-5 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-success">Filter</button>
                <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
                <a asp-action="RoutePlan" class="btn btn-outline-info">Route Plan</a>
                <a asp-action="Create" class="btn btn-outline-primary ms-auto">Add Work Order</a>
            </div>
        </div>
    </div>

    @if (TempData["AlertMessage"] != null)
    {
        <div class="alert alert-success">@TempData["AlertMessage"]</div>
    }
    @if (TempData["AlertMessageDelete"] != null)
    {
        <div class="alert alert-success">@TempData["AlertMessageDelete"]</div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Title</th>
                    <th>Project</th>
                    <th>Scheduled</th>
                    <th>Status</th>
                    <th>Crew</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Project?.ProjectName</td>
                        <td>@item.ScheduledDate.ToString("yyyy-MMM-dd")</td>
                        <td>@item.Status</td>
                        <td>@(string.IsNullOrWhiteSpace(item.AssignedCrew) ? "-" : item.AssignedCrew)</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary" title="Edit">&#x270E;</a>
                            <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary" title="Details">&#x1F50E;</a>
                            <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger" title="Delete">&#x274C;</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_PagingNavBar" />
</form>
