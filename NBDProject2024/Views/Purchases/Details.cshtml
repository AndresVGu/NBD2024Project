@model NBDProject2024.Models.PurchaseRequest

@{
    ViewData["Title"] = "Purchase Request Details";
}

<partial name="_ViewHeading" />

@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-info">@TempData["AlertMessage"]</div>
}

<div class="card card-body mb-3">
    <div class="row g-2">
        <div class="col-md-3"><strong>ID:</strong> @Model.ID</div>
        <div class="col-md-3"><strong>Date:</strong> @Model.RequestDate.ToString("yyyy-MMM-dd")</div>
        <div class="col-md-3"><strong>Supplier:</strong> @Model.SupplierName</div>
        <div class="col-md-3"><strong>Status:</strong> @Model.Status</div>
    </div>
    <div class="mt-2"><strong>Notes:</strong> @Model.Notes</div>
    <div class="mt-2"><strong>Approved By:</strong> @(string.IsNullOrWhiteSpace(Model.ApprovedBy) ? "-" : Model.ApprovedBy)</div>
    <div><strong>Approved On:</strong> @(Model.ApprovedOn.HasValue ? Model.ApprovedOn.Value.ToLocalTime().ToString("yyyy-MMM-dd HH:mm") : "-")</div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        @if (Model.Status == NBDProject2024.Models.PurchaseRequestStatus.Draft && Model.Lines.Any())
        {
            <form asp-action="Submit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-sm btn-outline-primary">Submit</button>
            </form>
        }

        @if (User.IsInRole("Admin") && (Model.Status == NBDProject2024.Models.PurchaseRequestStatus.Submitted || Model.Status == NBDProject2024.Models.PurchaseRequestStatus.PartiallyReceived))
        {
            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-sm btn-outline-success">Approve</button>
            </form>
        }

        @if (Model.Status != NBDProject2024.Models.PurchaseRequestStatus.Received && Model.Status != NBDProject2024.Models.PurchaseRequestStatus.Cancelled)
        {
            <form asp-action="Cancel" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ID" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-6">
        <div class="card card-body h-100">
            <h6 class="mb-3">Request Lines</h6>
            <form asp-action="AddLine" method="post" class="row g-2 mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ID" />
                <div class="col-md-5">
                    <select name="materialID" class="form-control" asp-items="ViewBag.MaterialID"></select>
                </div>
                <div class="col-md-3">
                    <input name="requestedQty" type="number" min="0.01" step="0.01" class="form-control" placeholder="Qty" />
                </div>
                <div class="col-md-3">
                    <input name="estimatedUnitCost" type="number" min="0" step="0.01" class="form-control" placeholder="Est. Cost" />
                </div>
                <div class="col-md-1">
                    <button class="btn btn-outline-primary w-100" type="submit">+</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Material</th>
                            <th>Requested</th>
                            <th>Est. Cost</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Lines.Any())
                        {
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td>@line.Material?.Name</td>
                                    <td>@line.RequestedQty.ToString("0.##")</td>
                                    <td>@line.EstimatedUnitCost.ToString("C2")</td>
                                    <td>@((line.RequestedQty * line.EstimatedUnitCost).ToString("C2"))</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-muted text-center">No lines yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card card-body h-100">
            <h6 class="mb-3">Reception (Supplier + Real Cost)</h6>
            <form asp-action="Receive" method="post" class="row g-2 mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.ID" />
                <div class="col-md-6">
                    <select name="materialID" class="form-control" asp-items="ViewBag.MaterialID"></select>
                </div>
                <div class="col-md-6">
                    <select name="stockLocationID" class="form-control" asp-items="ViewBag.StockLocationID"></select>
                </div>
                <div class="col-md-4">
                    <input name="receivedDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <input name="receivedQty" type="number" min="0.01" step="0.01" class="form-control" placeholder="Qty" />
                </div>
                <div class="col-md-3">
                    <input name="actualUnitCost" type="number" min="0" step="0.01" class="form-control" placeholder="Real Cost" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-success w-100" type="submit">Recv</button>
                </div>
                <div class="col-md-12">
                    <input name="supplierInvoice" class="form-control" placeholder="Supplier Invoice (optional)" />
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Material</th>
                            <th>Location</th>
                            <th>Qty</th>
                            <th>Real Cost</th>
                            <th>Invoice</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Receipts.Any())
                        {
                            @foreach (var r in Model.Receipts.OrderByDescending(x => x.ReceivedDate))
                            {
                                <tr>
                                    <td>@r.ReceivedDate.ToString("yyyy-MMM-dd")</td>
                                    <td>@r.Material?.Name</td>
                                    <td>@r.StockLocation?.Name</td>
                                    <td>@r.ReceivedQty.ToString("0.##")</td>
                                    <td>@r.ActualUnitCost.ToString("C2")</td>
                                    <td>@r.SupplierInvoice</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-muted text-center">No receipts yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Purchases</a>
    <a asp-controller="Inventory" asp-action="Index" class="btn btn-outline-primary">Inventory</a>
</div>
