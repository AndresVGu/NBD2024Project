                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12 col-xl-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Top Users</h6>
                <div class="table-responsive">
