                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card db-panel-card h-100">
            <div class="card-body d-flex flex-column justify-content-center">
                <h6 class="text-center mb-3">Traffic Sources</h6>
                <div id="trafficSourcesChart" class="db-donut-height"></div>
                <div class="db-traffic-list mt-3">
                    <div class="d-flex justify-content-between"><span>Direct</span><strong>42%</strong></div>
                    <div class="d-flex justify-content-between"><span>Organic Search</span><strong>28%</strong></div>
                    <div class="d-flex justify-content-between"><span>Social Media</span><strong>18%</strong></div>
