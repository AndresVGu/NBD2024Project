@model NBDProject2024.ViewModels.DashboardVM
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    string scopeLabel = Model.UseMyScope ? "My Scope" : "Global Scope";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h4 class="mb-0">Operations Dashboard</h4>
        <small class="text-muted">Data is filtered by user scope and role permissions.</small>
    </div>

    @if (Model.CanToggleScope)
    {
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="hidden" name="myScope" value="@(!Model.UseMyScope)" />
            <button type="submit" class="btn btn-outline-primary btn-sm">
                Switch to @(Model.UseMyScope ? "Global" : "My") Scope
            </button>
        </form>
    }

</div>

<div class="alert alert-light border mb-4">
    <strong>Current Scope:</strong> @scopeLabel
    @if (User.IsInRole("Guest") || User.HasClaim("GuestMode", "true"))
    {
        <span class="ms-2 text-muted">(Guest mode is always limited to your own records.)</span>
    }
</div>

<div class="row g-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Clients</span>
                    <div class="db-icon-circle text-primary"><i class="fa-solid fa-address-book"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.ScopedClients</h4>
                <small class="text-muted">My created: @Model.MyCreatedClients</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Projects</span>
                    <div class="db-icon-circle text-info"><i class="fa-solid fa-diagram-project"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.ScopedProjects</h4>
                <small class="text-muted">Without bids: @Model.ProjectsWithoutBids</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Work Orders</span>
                    <div class="db-icon-circle text-warning"><i class="fa-solid fa-clipboard-check"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.TotalWorkOrders</h4>
                <small class="text-muted">Pending/Scheduled: @Model.PendingWorkOrders</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Reorder Alerts</span>
                    <div class="db-icon-circle text-success"><i class="fa-solid fa-route"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.ReorderAlerts</h4>
                <small class="text-muted">Today Route Stops: @Model.TodayRouteStops</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12 col-xl-8">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h6 class="mb-0">Work Orders and Hours Control (Today)</h6>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="WorkOrders" asp-action="Index" class="btn btn-sm btn-outline-primary">Open Work Orders</a>
                        <a asp-controller="WorkOrders" asp-action="RoutePlan" asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-info">Route Plan</a>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-4">
                        <div class="border rounded p-3">
                            <small class="text-muted d-block">Estimated Hours</small>
                            <h5 class="mb-0">@Model.TodayEstimatedHours.ToString("0.##") h</h5>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="border rounded p-3">
                            <small class="text-muted d-block">Actual Hours</small>
                            <h5 class="mb-0">@Model.TodayActualHours.ToString("0.##") h</h5>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="border rounded p-3">
                            <small class="text-muted d-block">Variance</small>
                            <h5 class="mb-0 @(Model.TodayHoursVariance > 0 ? "text-danger" : "text-success")">@Model.TodayHoursVariance.ToString("0.##") h</h5>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0 db-table">
                        <thead>
                            <tr>
                                <th>Recent Work Order</th>
                                <th>Context</th>
                                <th>Date</th>
                                <th class="text-center">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentWorkOrders.Any())
                            {
                                @foreach (var item in Model.RecentWorkOrders)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        <td>@item.SubTitle</td>
                                        <td>@(item.CreatedOn.HasValue ? item.CreatedOn.Value.ToString("yyyy-MMM-dd") : "-")</td>
                                        <td class="text-center">
                                            <a asp-controller="WorkOrders" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted">No recent work orders in this scope.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Crew Skills Usage</h6>
                <p class="text-muted mb-2">Employees with skills: <strong>@Model.EmployeesWithSkills</strong></p>
                <p class="text-muted">Total WO skill assignments: <strong>@Model.TotalSkillAssignments</strong></p>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0 db-table">
                        <thead>
                            <tr>
                                <th>Skill</th>
                                <th class="text-end">Assignments</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SkillUsage.Any())
                            {
                                @foreach (var skill in Model.SkillUsage)
                                {
                                    <tr>
                                        <td>@skill.Skill</td>
                                        <td class="text-end">@skill.Count</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-center text-muted">No skill assignments yet.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="EmployeeSkills" asp-action="Index" class="btn btn-sm btn-outline-primary">Manage Employee Skills</a>
                    <a asp-controller="WorkOrders" asp-action="Index" class="btn btn-sm btn-outline-secondary">Assign Crew by Work Order</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12 col-lg-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Recent Clients</h6>
                <ul class="list-group list-group-flush">
                    @if (Model.RecentClients.Any())
                    {
                        @foreach (var item in Model.RecentClients)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <div>@item.Title</div>
                                    <small class="text-muted">@item.SubTitle</small>
                                </div>
                                <a asp-controller="Clients" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Open</a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item px-0 text-muted">No client activity in this scope.</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Recent Projects</h6>
                <ul class="list-group list-group-flush">
                    @if (Model.RecentProjects.Any())
                    {
                        @foreach (var item in Model.RecentProjects)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <div>@item.Title</div>
                                    <small class="text-muted">@item.SubTitle</small>
                                </div>
                                <a asp-controller="Projects" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Open</a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item px-0 text-muted">No project activity in this scope.</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <h6 class="mb-3">Recent Bids</h6>
                <p class="text-muted mb-2">Bids this month: <strong>@Model.BidsThisMonth</strong></p>
                <ul class="list-group list-group-flush">
                    @if (Model.RecentBids.Any())
                    {
                        @foreach (var item in Model.RecentBids)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <div>@item.Title</div>
                                    <small class="text-muted">@item.SubTitle</small>
                                </div>
                                <a asp-controller="Bids" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Open</a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item px-0 text-muted">No bid activity in this scope.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12 col-xl-4">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0">Inventory Reorder Watch</h6>
                    <a asp-controller="Inventory" asp-action="Index" class="btn btn-sm btn-outline-primary">Open</a>
                </div>
                @if (Model.ReorderAlertItems.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.ReorderAlertItems)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <div>@item.Material</div>
                                    <small class="text-muted">@item.Location</small>
                                </div>
                                <span class="badge text-bg-warning">@item.OnHand.ToString("0.##") / @item.Minimum.ToString("0.##")</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">No active reorder alerts.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0">Work Orders by Status</h6>
                    <small class="text-muted">@scopeLabel</small>
                </div>
                <div style="min-height: 280px;">
                    <canvas id="woStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card db-panel-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0">Weekly Hours Trend (Last 7 Days)</h6>
                    <small class="text-muted">Estimated vs Actual</small>
                </div>
                <div style="min-height: 280px;">
                    <canvas id="weeklyHoursChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card db-panel-card mt-4">
    <div class="card-body">
        <h6 class="mb-2">Pending Placeholder Section</h6>
        <p class="text-muted mb-0">
            Sales forecasting charts and financial breakdown widgets were kept out for now because there is no consistent domain source yet.
            This section can be replaced later with real revenue models.
        </p>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            if (!window.Chart) {
                return;
            }

            const statusLabels = @Html.Raw(JsonSerializer.Serialize(Model.WorkOrderStatusChart.Select(s => s.Label)));
            const statusValues = @Html.Raw(JsonSerializer.Serialize(Model.WorkOrderStatusChart.Select(s => s.Count)));
            const weekLabels = @Html.Raw(JsonSerializer.Serialize(Model.WeeklyHoursTrend.Select(p => p.Label)));
            const weekEstimated = @Html.Raw(JsonSerializer.Serialize(Model.WeeklyHoursTrend.Select(p => p.EstimatedHours)));
            const weekActual = @Html.Raw(JsonSerializer.Serialize(Model.WeeklyHoursTrend.Select(p => p.ActualHours)));

            const statusCanvas = document.getElementById("woStatusChart");
            if (statusCanvas) {
                new Chart(statusCanvas, {
                    type: "doughnut",
                    data: {
                        labels: statusLabels,
                        datasets: [{
                            label: "Work Orders",
                            data: statusValues,
                            backgroundColor: ["#94a3b8", "#3b82f6", "#f59e0b", "#22c55e", "#ef4444"],
                            borderColor: "#ffffff",
                            borderWidth: 2,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: "62%",
                        plugins: {
                            legend: {
                                display: true,
                                position: "bottom"
                            }
                        }
                    }
                });
            }

            const hoursCanvas = document.getElementById("weeklyHoursChart");
            if (hoursCanvas) {
                new Chart(hoursCanvas, {
                    type: "line",
                    data: {
                        labels: weekLabels,
                        datasets: [
                            {
                                label: "Estimated",
                                data: weekEstimated,
                                borderColor: "#3b82f6",
                                backgroundColor: "rgba(59,130,246,0.15)",
                                tension: 0.35,
                                fill: true,
                                pointRadius: 3
                            },
                            {
                                label: "Actual",
                                data: weekActual,
                                borderColor: "#ef4444",
                                backgroundColor: "rgba(239,68,68,0.10)",
                                tension: 0.35,
                                fill: false,
                                pointRadius: 3
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            }
        })();
    </script>
}
