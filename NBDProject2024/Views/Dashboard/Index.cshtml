@model NBDProject2024.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Total Revenue</span>
                    <div class="db-icon-circle text-success"><i class="fa-solid fa-chart-line"></i></div>
                </div>
                <h4 class="db-metric-value">$@Model.Revenue.ToString("N0")</h4>
                <small class="text-success fw-semibold">+2.65%</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Orders</span>
                    <div class="db-icon-circle text-warning"><i class="fa-solid fa-shopping-cart"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.Orders.ToString("N0")</h4>
                <small class="text-warning fw-semibold">-0.82%</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Customers</span>
                    <div class="db-icon-circle text-primary"><i class="fa-solid fa-users"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.Customers.ToString("N0")</h4>
                <small class="text-primary fw-semibold">-6.24%</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card db-metric-card">
            <div class="card-body">
                <div class="db-metric-head">
                    <span>Growth</span>
                    <div class="db-icon-circle text-success"><i class="fa-solid fa-arrow-trend-up"></i></div>
                </div>
                <h4 class="db-metric-value">@Model.Growth.ToString("N2")%</h4>
                <small class="text-success fw-semibold">+10.51%</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-12 col-xl-9">
        <div class="card db-panel-card db-sales-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                    <h5 class="mb-0">Sales Analytics</h5>
                    <div class="db-sales-metrics">
                        <span>Income: <strong>$2,371</strong></span>
                        <span>Sales: <strong>258</strong></span>
                        <span>Conversion Rate: <strong>3.6%</strong></span>
                    </div>
                </div>
                <div id="salesAnalyticsChart" class="db-chart-height"></div>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-3">
        <div class="d-flex flex-column gap-4 h-100">
            <div class="card db-promo-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="mb-0 text-white">Improve Business Performance</h6>
                        <i class="fa-solid fa-chart-pie fa-lg text-white-50"></i>
                    </div>
                    <p class="text-white-50 my-3">Use insights to optimize your strategy this quarter.</p>
                    <button class="btn btn-light btn-sm fw-semibold">View Reports</button>
                </div>
            </div>

            <div class="card db-panel-card flex-grow-1">
                <div class="card-body">
                    <h6 class="mb-3">Top Categories</h6>

                    <div class="db-progress-item">
                        <div class="d-flex justify-content-between"><span>Electronics</span><span>75%</span></div>
                        <div class="progress"><div class="progress-bar w-75"></div></div>
                    </div>
                    <div class="db-progress-item">
                        <div class="d-flex justify-content-between"><span>Software</span><span>68%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 68%"></div></div>
                    </div>
                    <div class="db-progress-item">
                        <div class="d-flex justify-content-between"><span>Services</span><span>60%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 60%"></div></div>
                    </div>
                    <div class="db-progress-item">
                        <div class="d-flex justify-content-between"><span>Hardware</span><span>84%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 84%"></div></div>
                    </div>
                    <div class="db-progress-item">
                        <div class="d-flex justify-content-between"><span>Accessories</span><span>71%</span></div>
                        <div class="progress"><div class="progress-bar" style="width: 71%"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

